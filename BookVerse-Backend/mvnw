# ----------------------------------------------------------------------------
# Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

set -e

# OS specific support.  $var _must_ be set to either true or false.
cygwin=false
darwin=false
os400=false
case "`uname`" in
  CYGWIN*) cygwin=true;;
  Darwin*) darwin=true;;
  OS400*) os400=true;;
esac

PRG="$0"

while [ -h "$PRG" ] ; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done

PRGDIR=`dirname "$PRG"`
BASEDIR=`cd "$PRGDIR/.." >/dev/null; pwd`

# Reset the classworlds conf after backslashes help
# (shaking the core of the problem, so to speak)
case "$BASEDIR" in
  *[\\\\]*) BASEDIR=`echo "$BASEDIR" | sed 's/[\\\\]/\//g'`;;
esac

# For Cygwin, ensure paths are in UNIX format before anything is touched
if $cygwin; then
  [ -n "$JAVA_HOME" ] && JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
  [ -n "$CLASSPATH" ] && CLASSPATH=`cygpath --path --unix "$CLASSPATH"`
fi

# For OS400
if $os400; then
  # Support for older versions of OS400 which don't have a temp directory
  if [ -z "$TEMP" ]; then
    TEMP=/tmp
  fi
fi

# Find the project base dir, i.e. the directory that contains the folder ".mvn".
# Fallback to current working directory if not found.

project_base_dir=$PRGDIR
while [ ! -d "$project_base_dir/.mvn" ]; do
  if [ "$project_base_dir" = "/" ]; then
    project_base_dir=$PRGDIR
    break
  fi
  project_base_dir=`cd "$project_base_dir/.." >/dev/null; pwd`
done

# Execute the maven wrapper
export MAVEN_PROJECTBASEDIR=${MAVEN_PROJECTBASEDIR:-"$project_base_dir"}

# Add -Dmaven.multiModuleProjectDirectory
MAVEN_OPTS="-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR} ${MAVEN_OPTS}"

# Check for a maven configuration file ".mvn/jvm.config"
if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/jvm.config" ]; then
  JVM_CONFIG_MAVEN_OPTS=`cat "$MAVEN_PROJECTBASEDIR/.mvn/jvm.config" | xargs`
  MAVEN_OPTS="${MAVEN_OPTS} ${JVM_CONFIG_MAVEN_OPTS}"
fi

# Check for a maven configuration file ".mvn/maven.config"
if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/maven.config" ]; then
  MAVEN_CONFIG_MAVEN_OPTS=`cat "$MAVEN_PROJECTBASEDIR/.mvn/maven.config" | xargs`
  MAVEN_OPTS="${MAVEN_OPTS} ${MAVEN_CONFIG_MAVEN_OPTS}"
fi

# For OS400
if $os400; then
  # Fix for OS400
  MAVEN_OPTS=`echo "$MAVEN_OPTS" | sed 's/-Xmx[0-9]*[mg]//g'`
fi

# Set the Maven Wrapper JAR location
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

# If the JAR doesn't exist, we can't run the wrapper
if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Error: Could not find maven-wrapper.jar at $WRAPPER_JAR"
  exit 1
fi

# Run the wrapper
exec java $MAVEN_OPTS -classpath "$WRAPPER_JAR" "$WRAPPER_LAUNCHER" "$@"
